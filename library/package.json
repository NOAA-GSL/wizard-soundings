{
    "name": "@noaa-gsl/wizard-soundings",
    "publishConfig": {
        "access": "public"
    },
    "version": "1.0.1",
    "description": "An extension of D3 that visualizes upper-air soundings.",
    "type": "module",
    "license": "Apache-2.0",
    "main": "./dist/wizard-soundings.umd.cjs",
    "module": "./dist/wizard-soundings.es.js",
    "exports": {
        ".": {
            "import": "./dist/wizard-soundings.es.js",
            "require": "./dist/wizard-soundings.umd.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist"
    ],
    "homepage": "https://github.com/NOAA-GSL/wizard-soundings",
    "scripts": {
        "dev": "vite",
        "build:dev": "vite build --config vite.config.dev.js",
        "postbuild:dev": "yalc push",
        "build": "vite build --config vite.config.prod.js",
        "lint": "eslint .",
        "preview": "vite preview",
        "size": "npx vite-bundle-visualizer"
    },
    "devDependencies": {
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.1.2",
        "vite": "^8.0.8"
    },
    "peerDependencies": {
        "d3": "^7.9.0",
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19"
    }
}
